<Window x:Class="Technopark.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Технопарк — Вход" Height="420" Width="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" Margin="50,0">

            <!-- Логотип / заголовок -->
            <TextBlock Text="Технопарк" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Кванториум" FontSize="13" Foreground="#888"
                       HorizontalAlignment="Center" Margin="0,0,0,36"/>

            <!-- Логин -->
            <TextBlock Text="Логин" FontSize="13" Margin="0,0,0,6"/>
            <TextBox x:Name="LoginBox" Height="38" FontSize="14"
                     Padding="10,8" BorderBrush="#CCC" BorderThickness="1"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль" FontSize="13" Margin="0,16,0,6"/>
            <PasswordBox x:Name="PasswordBox" Height="38" FontSize="14"
                         Padding="10,8" BorderBrush="#CCC" BorderThickness="1"/>

            <!-- Ошибка -->
            <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12"
                       Margin="0,10,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

            <!-- Кнопка входа -->
            <Button x:Name="LoginBtn" Content="Войти" Height="42"
                    Margin="0,24,0,0" FontSize="14" FontWeight="SemiBold"
                    Background="#534AB7" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="LoginBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>