<Window x:Class="Technopark.Dialogs.ReferenceItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись справочника" Height="400" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" Text="Добавить запись" FontSize="16"
                       FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Название *" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB"
                     MaxLength="100" Margin="0,0,0,12"/>

            <StackPanel x:Name="DescriptionPanel" Visibility="Collapsed">
                <TextBlock Text="Описание" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionBox" Height="90" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB"
                         MaxLength="500" Margin="0,0,0,4"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="Опциональное поле, до 500 символов"
                           FontSize="11" Foreground="#9CA3AF"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="36" Margin="0,0,10,0"
                    BorderBrush="#D1D5DB" Background="White"
                    FontSize="13" Cursor="Hand" Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn" Content="Сохранить" Width="110" Height="36"
                    Background="#534AB7" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
