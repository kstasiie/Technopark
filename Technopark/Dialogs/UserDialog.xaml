<Window x:Class="Technopark.Dialogs.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь" Height="700" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Новый пользователь"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <TextBlock Text="Фамилия *" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="LastNameBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock Text="Имя *" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="FirstNameBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock Text="Отчество" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="MiddleNameBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock Text="Логин *" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="LoginBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock x:Name="PasswordLabel" Text="Пароль *"
                           FontSize="13" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Height="36" FontSize="13"
                             Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock Text="Роль *" FontSize="13" Margin="0,0,0,4"/>
                <ComboBox x:Name="RoleBox" Height="36" FontSize="13" Margin="0,0,0,10">
                    <ComboBoxItem Content="Администратор" Tag="Admin"/>
                    <ComboBoxItem Content="Наставник" Tag="Mentor" IsSelected="True"/>
                    <ComboBoxItem Content="Участник" Tag="Student"/>
                </ComboBox>

                <TextBlock Text="Должность (для наставника)"
                           FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="PositionBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock Text="Направление (для наставника)"
                           FontSize="13" Margin="0,0,0,4"/>
                <ComboBox x:Name="DirectionBox" Height="36" FontSize="13"
                          Margin="0,0,0,10"/>

                <TextBlock Text="Дата рождения (для участника, дд.мм.гггг)"
                           FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="BirthDateBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock Text="Email" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                <TextBlock Text="Телефон" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="PhoneBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="36" Margin="0,0,10,0"
                    BorderBrush="#D1D5DB" Background="White" FontSize="13"
                    Cursor="Hand" Click="CancelBtn_Click"/>
            <Button Content="Сохранить" Width="110" Height="36"
                    Background="#534AB7" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>