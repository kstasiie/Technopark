<Window x:Class="Technopark.Dialogs.TeamDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Команда" Height="580" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" Text="Новая команда"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Основные поля -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Название команды *" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Год *" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="YearBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB"/>
            </StackPanel>
        </Grid>

        <!-- Добавление участника -->
        <TextBlock Grid.Row="2" Text="Участники команды"
                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Grid Grid.Row="2" Margin="0,28,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="StudentBox" Height="36" FontSize="13"
                      Grid.Column="0" Margin="0,0,8,0"/>
            <ComboBox x:Name="RoleBox" Height="36" FontSize="13"
                      Grid.Column="1" Margin="0,0,8,0"/>
            <Button Content="+ Добавить" Height="36" Padding="12,0"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Grid.Column="2" Click="AddMemberBtn_Click"/>
        </Grid>

        <!-- Список участников -->
        <Border Grid.Row="3" BorderBrush="#E5E7EB" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,0">
            <DataGrid x:Name="MembersGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0" RowHeight="38"
                      FontSize="13" Background="White"
                      CanUserResizeRows="False"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Участник"
                        Binding="{Binding StudentName}" Width="*"/>
                    <DataGridTextColumn Header="Роль в команде"
                        Binding="{Binding RoleName}" Width="150"/>
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Width="28" Height="26"
                                        Background="Transparent"
                                        BorderThickness="0" Cursor="Hand"
                                        Foreground="#EF4444"
                                        Tag="{Binding StudentId}"
                                        Click="RemoveMember_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="36" Margin="0,0,10,0"
                    BorderBrush="#D1D5DB" Background="White"
                    FontSize="13" Cursor="Hand" Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn" Content="Сохранить" Width="110" Height="36"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>