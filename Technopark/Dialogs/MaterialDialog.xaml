<Window x:Class="Technopark.Dialogs.MaterialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Материал проекта" Height="470" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" Text="Добавить материал" FontSize="16"
                       FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Тип материала *" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="TypeBox" Height="36" FontSize="13"
                      Margin="0,0,0,12"/>

            <TextBlock Text="Название *" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB" MaxLength="150"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Ссылка *" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="LinkBox" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB" MaxLength="255"
                     Margin="0,0,0,4"/>
            <TextBlock Text="Например: https://disk.example.com/file или путь к локальному файлу"
                       FontSize="11" Foreground="#9CA3AF"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>

            <TextBlock Text="Дата загрузки *" FontSize="13" Margin="0,0,0,4"/>
            <DatePicker x:Name="UploadDatePicker" Height="36" FontSize="13"
                        BorderBrush="#D1D5DB"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="36" Margin="0,0,10,0"
                    BorderBrush="#D1D5DB" Background="White"
                    FontSize="13" Cursor="Hand" Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn" Content="Сохранить" Width="110" Height="36"
                    Background="#534AB7" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
