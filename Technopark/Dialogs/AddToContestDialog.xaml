<Window x:Class="Technopark.Dialogs.AddToContestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация на конкурс" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Добавить проект на конкурс" FontSize="16"
                       FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Конкурс *" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="ContestBox" Height="36" FontSize="13"
                      Margin="0,0,0,12"/>

            <TextBlock Text="Результат" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="ResultBox" Height="36" FontSize="13"
                      Margin="0,0,0,12"/>

            <TextBlock Text="Место (если призовое)" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="PlaceBox" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB"/>

            <TextBlock x:Name="NoContestsText"
                       Text="Этот проект уже зарегистрирован на все доступные конкурсы. Добавьте новый конкурс через раздел «Конкурсы»."
                       FontSize="12" Foreground="#9CA3AF" TextWrapping="Wrap"
                       Margin="0,12,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="36" Margin="0,0,10,0"
                    BorderBrush="#D1D5DB" Background="White"
                    FontSize="13" Cursor="Hand" Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn" Content="Сохранить" Width="110" Height="36"
                    Background="#534AB7" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>