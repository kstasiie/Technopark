<Window x:Class="Technopark.Dialogs.ContestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конкурс" Height="600" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" Text="Новый конкурс"
                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <TextBlock Text="Название *" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Организатор *" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="OrganizerBox" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Уровень *" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="LevelBox" Height="36" FontSize="13"
                      Margin="0,0,0,12"/>

            <TextBlock Text="Дата проведения *" FontSize="13" Margin="0,0,0,4"/>
            <DatePicker x:Name="DatePicker" Height="36"
                        FontSize="13" Margin="0,0,0,12"/>

            <!-- Участие проектов -->
            <TextBlock Text="Участие проектов" FontSize="14"
                       FontWeight="SemiBold" Margin="0,8,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ProjectBox" Height="36" FontSize="13"
                          Grid.Column="0"/>
                <Button Content="+ Добавить" Grid.Column="1" Height="36"
                        Margin="8,0,0,0" Padding="10,0"
                        Background="#534AB7" Foreground="White"
                        BorderThickness="0" FontSize="13" Cursor="Hand"
                        Click="AddParticipationBtn_Click"/>
            </Grid>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                <DataGrid x:Name="ParticipationsGrid"
                          AutoGenerateColumns="False" IsReadOnly="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0" RowHeight="38"
                          FontSize="12" Background="White"
                          CanUserResizeRows="False"
                          CanUserAddRows="False"
                          MaxHeight="160">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Проект"
                            Binding="{Binding ProjectName}" Width="*"
                            IsReadOnly="True"/>
                        <DataGridComboBoxColumn Header="Результат"
                            SelectedValueBinding="{Binding ResultId}"
                            Width="120"/>
                        <DataGridTextColumn Header="Место"
                            Binding="{Binding Place}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="36" Margin="0,0,10,0"
                    BorderBrush="#D1D5DB" Background="White"
                    FontSize="13" Cursor="Hand" Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn" Content="Сохранить" Width="110" Height="36"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>