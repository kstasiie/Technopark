<Window x:Class="Technopark.Dialogs.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проект" Height="640" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Новый проект"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <TextBlock Text="Название *" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Height="36" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

                <TextBlock Text="Описание" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionBox" Height="80" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Направление *" FontSize="13" Margin="0,0,0,4"/>
                <ComboBox x:Name="DirectionBox" Height="36" FontSize="13"
                          Margin="0,0,0,12"/>

                <TextBlock Text="Статус *" FontSize="13" Margin="0,0,0,4"/>
                <ComboBox x:Name="StatusBox" Height="36" FontSize="13"
                          Margin="0,0,0,12"/>

                <TextBlock Text="Наставник *" FontSize="13" Margin="0,0,0,4"/>
                <ComboBox x:Name="MentorBox" Height="36" FontSize="13"
                          Margin="0,0,0,12"/>

                <TextBlock Text="Команда *" FontSize="13" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="TeamBox" Height="36" FontSize="13"
                              Grid.Column="0"/>
                    <Button Content="+ Новая" Grid.Column="1" Height="36"
                            Margin="8,0,0,0" Padding="10,0"
                            BorderBrush="#D1D5DB" Background="White"
                            FontSize="13" Cursor="Hand"
                            Click="NewTeamBtn_Click"/>
                </Grid>

                <StackPanel x:Name="NewTeamPanel" Visibility="Collapsed"
                            Margin="0,4,0,12">
                    <TextBlock Text="Название новой команды"
                               FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewTeamNameBox" Height="36" FontSize="13"
                                 Padding="10,8" BorderBrush="#534AB7" Grid.Column="0"/>
                        <Button Content="Создать" Grid.Column="1" Height="36"
                                Margin="8,0,0,0" Padding="10,0"
                                Background="#534AB7" Foreground="White"
                                BorderThickness="0" FontSize="13" Cursor="Hand"
                                Click="CreateTeamBtn_Click"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="Дата начала *" FontSize="13" Margin="0,4,0,4"/>
                <DatePicker x:Name="StartDatePicker" Height="36"
                            FontSize="13" Margin="0,0,0,12"/>

                <TextBlock Text="Плановая дата завершения"
                           FontSize="13" Margin="0,0,0,4"/>
                <DatePicker x:Name="EndDatePicker" Height="36" FontSize="13"/>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="36" Margin="0,0,10,0"
                    BorderBrush="#D1D5DB" Background="White"
                    FontSize="13" Cursor="Hand" Click="CancelBtn_Click"/>
            <Button x:Name="SaveBtn" Content="Сохранить" Width="110" Height="36"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>