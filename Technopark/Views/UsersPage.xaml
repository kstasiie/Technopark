<Page x:Class="Technopark.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтры и поиск -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox x:Name="SearchBox" Width="240" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB"
                     VerticalContentAlignment="Center"
                     Text="Поиск по имени или логину..."
                     Foreground="#9CA3AF"
                     GotFocus="SearchBox_GotFocus"
                     LostFocus="SearchBox_LostFocus"
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="RoleFilter" Width="160" Height="36"
                      FontSize="13" Margin="10,0,0,0"
                      SelectionChanged="RoleFilter_SelectionChanged">
                <ComboBoxItem Content="Все роли" IsSelected="True"/>
                <ComboBoxItem Content="Администратор"/>
                <ComboBoxItem Content="Наставник"/>
                <ComboBoxItem Content="Участник"/>
            </ComboBox>

            <Button Content="+ Добавить пользователя" Height="36"
                    Margin="10,0,0,0" Padding="14,0"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="AddUserBtn_Click"/>
        </StackPanel>

        <!-- Таблица пользователей -->
        <Border Grid.Row="1" Background="White" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="UsersGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      RowHeight="44"
                      FontSize="13"
                      Background="White"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionChanged="UsersGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding DisplayName}" Width="*"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="130"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding RoleDisplay}" Width="110"/>
                    <DataGridTextColumn Header="Должность / Класс"
                        Binding="{Binding PositionOrClass}" Width="160"/>
                    <DataGridTextColumn Header="Направление"
                        Binding="{Binding DirectionName}" Width="120"/>
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Width="30" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Tag="{Binding UserId}"
                        Click="EditUser_Click"/>
                                    <Button Content="🗑️" Width="30" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Tag="{Binding UserId}"
                        Click="DeleteUser_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>