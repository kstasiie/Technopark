<Page x:Class="Technopark.Views.StudentDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="64" Height="64"
                            CornerRadius="32" Background="#993C1D">
                        <TextBlock x:Name="AvatarText" Foreground="White"
                                   FontSize="22" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="FullNameText" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="EditBtn" Content="✏️ Редактировать" Padding="14,8"
                                Background="#534AB7" Foreground="White" BorderThickness="0"
                                FontSize="13" Cursor="Hand" Margin="0,0,8,0"
                                Click="EditBtn_Click"/>
                        <Button x:Name="DeleteBtn" Content="🗑️ Удалить" Padding="14,8"
                                Background="White" Foreground="#DC2626" BorderBrush="#DC2626"
                                BorderThickness="1" FontSize="13" Cursor="Hand"
                                Click="DeleteBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="ContactsBlock" Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Личные данные" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock x:Name="BirthDateText" FontSize="13" Margin="0,2"/>
                    <TextBlock x:Name="EmailText" FontSize="13" Margin="0,2"/>
                    <TextBlock x:Name="PhoneText" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Команды" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="TeamsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="13" Foreground="#534AB7"
                                               Cursor="Hand" TextDecorations="Underline"
                                               Text="{Binding Name}" Tag="{Binding Id}"
                                               MouseLeftButtonDown="TeamLink_Click"/>
                                    <TextBlock Grid.Column="1" FontSize="13" Foreground="#6B7280"
                                               Text="{Binding Role}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="Конкурсы" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <DataGrid x:Name="ContestsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" RowHeight="38" FontSize="13" Background="White"
                              CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Конкурс" Binding="{Binding ContestName}" Width="*"/>
                            <DataGridTextColumn Header="Проект" Binding="{Binding ProjectName}" Width="160"/>
                            <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="120"/>
                            <DataGridTextColumn Header="Место" Binding="{Binding Place}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>