<Page x:Class="Technopark.Views.ContestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox x:Name="SearchBox" Width="220" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB"
                     VerticalContentAlignment="Center"
                     Text="Поиск по названию..."
                     Foreground="#9CA3AF"
                     GotFocus="SearchBox_GotFocus"
                     LostFocus="SearchBox_LostFocus"
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="LevelFilter" Width="160" Height="36"
                      FontSize="13" Margin="10,0,0,0"
                      SelectionChanged="Filter_Changed"/>

            <Button x:Name="AddContestBtn" Content="+ Добавить конкурс"
                    Height="36" Margin="10,0,0,0" Padding="14,0"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="AddContestBtn_Click"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="ContestsGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0" RowHeight="44"
                      FontSize="13" Background="White"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionChanged="ContestsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название"
                        Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Организатор"
                        Binding="{Binding Organizer}" Width="180"/>
                    <DataGridTextColumn Header="Уровень"
                        Binding="{Binding Level.Name}" Width="130"/>
                    <DataGridTextColumn Header="Дата"
                        Binding="{Binding DateDisplay}" Width="100"/>
                    <DataGridTextColumn Header="Участий"
                        Binding="{Binding ParticipationCount}" Width="80"/>
                    <DataGridTemplateColumn x:Name="ActionsColumn" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Width="30" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Tag="{Binding}"
                        Click="EditContest_Click"/>
                                    <Button Content="🗑️" Width="30" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Tag="{Binding}"
                        Click="DeleteContest_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>