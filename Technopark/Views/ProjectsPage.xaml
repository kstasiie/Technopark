<Page x:Class="Technopark.Views.ProjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox x:Name="SearchBox" Width="220" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB"
                     VerticalContentAlignment="Center"
                     Text="Поиск по названию..."
                     Foreground="#9CA3AF"
                     GotFocus="SearchBox_GotFocus"
                     LostFocus="SearchBox_LostFocus"
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="DirectionFilter" Width="150" Height="36"
                      FontSize="13" Margin="10,0,0,0"
                      SelectionChanged="Filter_Changed"/>

            <ComboBox x:Name="StatusFilter" Width="150" Height="36"
                      FontSize="13" Margin="10,0,0,0"
                      SelectionChanged="Filter_Changed"/>

            <Button x:Name="AddProjectBtn" Content="+ Добавить проект"
                    Height="36" Margin="10,0,0,0" Padding="14,0"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="AddProjectBtn_Click"/>
        </StackPanel>

        <!-- Таблица -->
        <Border Grid.Row="1" Background="White" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="ProjectsGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0" RowHeight="44"
                      FontSize="13" Background="White"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionChanged="ProjectsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название"
                        Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Направление"
                        Binding="{Binding Direction.Name}" Width="120"/>
                    <DataGridTextColumn Header="Наставник"
                        Binding="{Binding Mentor.FullName}" Width="180"/>
                    <DataGridTextColumn Header="Команда"
                        Binding="{Binding Team.Name}" Width="130"/>
                    <DataGridTextColumn Header="Дата начала"
                        Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}"
                        Width="100"/>
                    <DataGridTextColumn Header="Статус"
                        Binding="{Binding Status.Name}" Width="120"/>
                    <DataGridTemplateColumn x:Name="ActionsColumn" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Width="30" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" ToolTip="Редактировать"
                        Tag="{Binding}"
                        Click="EditProject_Click"/>
                                    <Button Content="🗑️" Width="30" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" ToolTip="Удалить"
                        Tag="{Binding}"
                        Click="DeleteProject_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>