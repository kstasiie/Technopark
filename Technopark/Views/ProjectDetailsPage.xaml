<Page x:Class="Technopark.Views.ProjectDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="ProjectNameText" FontSize="22"
                                       FontWeight="Bold" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border x:Name="StatusBadge" Background="#E1F5EE"
                                        CornerRadius="4" Padding="8,3">
                                    <TextBlock x:Name="StatusText" FontSize="12"
                                               Foreground="#0F6E56"/>
                                </Border>
                                <TextBlock x:Name="DirectionText" FontSize="13"
                                           Foreground="#6B7280"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="EditBtn" Content="✏️ Редактировать"
            Padding="14,8" Background="#534AB7"
            Foreground="White" BorderThickness="0"
            FontSize="13" Cursor="Hand" Margin="0,0,8,0"
            Click="EditBtn_Click"/>
                            <Button x:Name="DeleteBtn" Content="🗑️ Удалить"
            Padding="14,8" Background="White"
            Foreground="#DC2626" BorderBrush="#DC2626"
            BorderThickness="1" FontSize="13" Cursor="Hand"
            Click="DeleteBtn_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="DescriptionText" FontSize="13"
                               Foreground="#374151" TextWrapping="Wrap"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- Основная инфо -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Основная информация" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Наставник:" Foreground="#6B7280" FontSize="13"/>
                        <TextBlock x:Name="MentorLink" Grid.Column="1"
                                   FontSize="13" Foreground="#534AB7"
                                   Cursor="Hand" TextDecorations="Underline"
                                   MouseLeftButtonDown="MentorLink_Click"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Команда:" Foreground="#6B7280" FontSize="13"/>
                        <TextBlock x:Name="TeamLink" Grid.Column="1"
                                   FontSize="13" Foreground="#534AB7"
                                   Cursor="Hand" TextDecorations="Underline"
                                   MouseLeftButtonDown="TeamLink_Click"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Дата начала:" Foreground="#6B7280" FontSize="13"/>
                        <TextBlock x:Name="StartDateText" Grid.Column="1" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Плановое завершение:" Foreground="#6B7280" FontSize="13"/>
                        <TextBlock x:Name="EndDateText" Grid.Column="1" FontSize="13"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Состав команды -->
            <Border Grid.Row="2" Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Состав команды" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="MembersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="13"
                                               Foreground="#534AB7" Cursor="Hand"
                                               TextDecorations="Underline"
                                               Text="{Binding Name}"
                                               Tag="{Binding StudentId}"
                                               MouseLeftButtonDown="MemberLink_Click"/>
                                    <TextBlock Grid.Column="1" FontSize="13"
                                               Foreground="#6B7280"
                                               Text="{Binding Role}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Участие в конкурсах -->
            <Border Grid.Row="3" Background="White" CornerRadius="8"
        BorderBrush="#E5E7EB" BorderThickness="1"
        Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Участие в конкурсах"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
                        <Button x:Name="AddToContestBtn" Grid.Column="1"
                    Content="+ Добавить на конкурс" Padding="12,6"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="12" Cursor="Hand"
                    Click="AddToContestBtn_Click"/>
                    </Grid>
                    <DataGrid x:Name="ContestsGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="None" HeadersVisibility="Column"
                              BorderThickness="0" RowHeight="38"
                              FontSize="12" Background="White"
                              CanUserResizeRows="False"
                              SelectionChanged="ContestsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Конкурс"
                    Binding="{Binding ContestName}" Width="*"/>
                            <DataGridTextColumn Header="Уровень"
                    Binding="{Binding Level}" Width="130"/>
                            <DataGridTextColumn Header="Результат"
                    Binding="{Binding Result}" Width="120"/>
                            <DataGridTextColumn Header="Место"
                    Binding="{Binding Place}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Материалы проекта -->
            <Border Grid.Row="4" Background="White" CornerRadius="8"
        BorderBrush="#E5E7EB" BorderThickness="1"
        Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Материалы проекта"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
                        <Button x:Name="AddMaterialBtn" Grid.Column="1"
                    Content="+ Добавить материал" Padding="12,6"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="12" Cursor="Hand"
                    Click="AddMaterialBtn_Click"/>
                    </Grid>
                    <DataGrid x:Name="MaterialsGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="None" HeadersVisibility="Column"
                              BorderThickness="0" RowHeight="38"
                              FontSize="12" Background="White"
                              CanUserResizeRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Название" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#534AB7"
                                                   TextDecorations="Underline"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding Link}"
                                                   Tag="{Binding Link}"
                                                   MouseLeftButtonDown="MaterialLink_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Тип"
                                Binding="{Binding TypeName}" Width="180"/>
                            <DataGridTextColumn Header="Дата загрузки"
                                Binding="{Binding UploadDateDisplay}" Width="120"/>
                            <DataGridTemplateColumn x:Name="MaterialActionsColumn" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏️" Width="30" Height="28"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Tag="{Binding Id}"
                                                ToolTip="Редактировать"
                                                Click="EditMaterial_Click"/>
                                            <Button Content="🗑️" Width="30" Height="28"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Tag="{Binding Id}"
                                                ToolTip="Удалить"
                                                Click="DeleteMaterial_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="NoMaterialsText"
                               Text="Материалов пока нет. Добавьте ссылку на документ, презентацию, фото или видео."
                               Foreground="#9CA3AF" FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>