<Page x:Class="Technopark.Views.PortfolioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <!-- Профиль -->
            <Border Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Padding="24" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="64" Height="64"
                            CornerRadius="32" Background="#534AB7">
                        <TextBlock x:Name="AvatarText" Text="УЧ"
                                   Foreground="White" FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="FullNameText" FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="SchoolText" FontSize="13"
                                   Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Статистика -->
            <UniformGrid x:Name="StatsGrid" Rows="1" Margin="0,0,0,24"/>

            <!-- Мои проекты -->
            <TextBlock Text="Мои проекты" FontSize="15"
                       FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Margin="0,0,0,24">
                <DataGrid x:Name="ProjectsGrid"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0" RowHeight="42"
                          FontSize="13" Background="White"
                          CanUserResizeRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Проект"
                            Binding="{Binding ProjectName}" Width="*"/>
                        <DataGridTextColumn Header="Направление"
                            Binding="{Binding Direction}" Width="130"/>
                        <DataGridTextColumn Header="Роль в команде"
                            Binding="{Binding TeamRole}" Width="160"/>
                        <DataGridTextColumn Header="Статус"
                            Binding="{Binding Status}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Конкурсы -->
            <TextBlock Text="Участие в конкурсах" FontSize="15"
                       FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Background="White" CornerRadius="8"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <DataGrid x:Name="ContestsGrid"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0" RowHeight="42"
                          FontSize="13" Background="White"
                          CanUserResizeRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Конкурс"
                            Binding="{Binding ContestName}" Width="*"/>
                        <DataGridTextColumn Header="Уровень"
                            Binding="{Binding Level}" Width="130"/>
                        <DataGridTextColumn Header="Проект"
                            Binding="{Binding ProjectName}" Width="160"/>
                        <DataGridTextColumn Header="Результат"
                            Binding="{Binding Result}" Width="120"/>
                        <DataGridTextColumn Header="Место"
                            Binding="{Binding Place}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>