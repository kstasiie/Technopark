<Page x:Class="Technopark.Views.TeamsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox x:Name="SearchBox" Width="220" Height="36" FontSize="13"
                     Padding="10,8" BorderBrush="#D1D5DB"
                     VerticalContentAlignment="Center"
                     Text="Поиск по названию..."
                     Foreground="#9CA3AF"
                     GotFocus="SearchBox_GotFocus"
                     LostFocus="SearchBox_LostFocus"
                     TextChanged="SearchBox_TextChanged"/>

            <Button x:Name="AddTeamBtn" Content="+ Добавить команду"
                    Height="36" Margin="10,0,0,0" Padding="14,0"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="AddTeamBtn_Click"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="TeamsGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0" RowHeight="44"
                      FontSize="13" Background="White"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionChanged="TeamsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название"
                        Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Год формирования"
                        Binding="{Binding FormationYear}" Width="140"/>
                    <DataGridTextColumn Header="Участников"
                        Binding="{Binding MemberCount}" Width="100"/>
                    <DataGridTextColumn Header="Проектов"
                        Binding="{Binding ProjectCount}" Width="100"/>
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Width="30" Height="28"
                                            Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding TeamId}"
                                            Click="EditTeam_Click"/>
                                    <Button Content="🗑️" Width="30" Height="28"
                                            Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding TeamId}"
                                            Click="DeleteTeam_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>