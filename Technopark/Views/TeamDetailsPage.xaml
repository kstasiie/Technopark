<Page x:Class="Technopark.Views.TeamDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="NameText" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="YearText" FontSize="13" Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="EditBtn" Content="✏️ Редактировать" Padding="14,8"
                                Background="#534AB7" Foreground="White" BorderThickness="0"
                                FontSize="13" Cursor="Hand" Margin="0,0,8,0"
                                Click="EditBtn_Click"/>
                        <Button x:Name="DeleteBtn" Content="🗑️ Удалить" Padding="14,8"
                                Background="White" Foreground="#DC2626" BorderBrush="#DC2626"
                                BorderThickness="1" FontSize="13" Cursor="Hand"
                                Click="DeleteBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Участники" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="MembersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="13" Foreground="#534AB7"
                                               Cursor="Hand" TextDecorations="Underline"
                                               Text="{Binding Name}" Tag="{Binding Id}"
                                               MouseLeftButtonDown="MemberLink_Click"/>
                                    <TextBlock Grid.Column="1" FontSize="13" Foreground="#6B7280"
                                               Text="{Binding Role}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="Проекты" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <DataGrid x:Name="ProjectsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" RowHeight="40" FontSize="13" Background="White"
                              CanUserResizeRows="False" SelectionChanged="ProjectsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Направление" Binding="{Binding Direction.Name}" Width="130"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status.Name}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>