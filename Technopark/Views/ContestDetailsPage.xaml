<Page x:Class="Technopark.Views.ContestDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="NameText" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="OrganizerText" FontSize="13" Foreground="#6B7280" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Border Background="#E6F1FB" CornerRadius="4" Padding="8,3">
                                <TextBlock x:Name="LevelText" FontSize="12" Foreground="#185FA5"/>
                            </Border>
                            <TextBlock x:Name="DateText" FontSize="13" Foreground="#6B7280"
                                       Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="EditBtn" Content="✏️ Редактировать" Padding="14,8"
                                Background="#534AB7" Foreground="White" BorderThickness="0"
                                FontSize="13" Cursor="Hand" Margin="0,0,8,0"
                                Click="EditBtn_Click"/>
                        <Button x:Name="DeleteBtn" Content="🗑️ Удалить" Padding="14,8"
                                Background="White" Foreground="#DC2626" BorderBrush="#DC2626"
                                BorderThickness="1" FontSize="13" Cursor="Hand"
                                Click="DeleteBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB"
                    BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="Участвующие проекты" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <DataGrid x:Name="ProjectsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" RowHeight="40" FontSize="13" Background="White"
                              CanUserResizeRows="False" SelectionChanged="ProjectsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Проект" Binding="{Binding ProjectName}" Width="*"/>
                            <DataGridTextColumn Header="Наставник" Binding="{Binding MentorName}" Width="180"/>
                            <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="120"/>
                            <DataGridTextColumn Header="Место" Binding="{Binding Place}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>